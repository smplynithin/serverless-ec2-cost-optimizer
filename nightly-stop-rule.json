{
  "Name": "nightly-ec2-stop",
  "ScheduleExpression": "cron(30 17 * * ? *)",
  "Description": "Triggers Lambda to stop dev EC2 instances at 11:00 PM IST (17:30 UTC) every day",
  "State": "ENABLED",
  "Targets": [
    {
      "Id": "ec2-lifecycle-manager-stop",
      "Arn": "arn:aws:lambda:us-east-1:YOUR_ACCOUNT_ID:function:ec2-lifecycle-manager",
      "Input": "{\"action\": \"stop\"}"
    }
  ]
}
